# ============================================================
# Flex OTP Service — Environment Configuration
# Copy this file to .env and update values as needed.
# ============================================================

# App
SECRET_KEY=change_this_to_a_random_64_char_string
DEBUG=false

# Database (SQLite default — change to PostgreSQL URL for production)
DATABASE_URL=sqlite+aiosqlite:///./flex_otp.db
# PostgreSQL example:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/flex_otp

# SMTP / Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=flexotpservice@gmail.com
EMAIL_APP_PASSWORD=jbmt fiov qyax khcl
SENDER_NAME=Flex OTP Service

# OTP Settings
OTP_EXPIRY_SECONDS=300
OTP_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5

# Rate Limiting
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW=60
BLOCK_DURATION=600

# Admin
ADMIN_USERNAME=flexadmin
ADMIN_PASSWORD=FlexAdmin@Secure2026!
SESSION_EXPIRE_HOURS=24
